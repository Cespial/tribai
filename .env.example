ANTHROPIC_API_KEY=sk-ant-...
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=estatuto-tributario
CHAT_MODEL=claude-sonnet-4-5-20250929

# Vercel KV (Redis) — optional, enables distributed rate limiting
# Without these, the app falls back to in-memory rate limiting
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Clerk — optional, enables authentication and plan management
# Without these, all users get the basic plan
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe — optional, enables Pro plan purchases
# Without these, plan selection is client-side only (no payment enforcement)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
